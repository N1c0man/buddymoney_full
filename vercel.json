{
  "redirects": [
    {
      "source": "/tools/budget-coach",
      "destination": "/coach",
      "permanent": true
    },
    {
      "source": "/mortgage-payoff",
      "destination": "/mortgage",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "buddymoney.com" }],
      "destination": "https://www.buddymoney.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "www.buddymoney.com" },
        { "type": "header", "key": "x-forwarded-proto", "value": "http" }
      ],
      "destination": "https://www.buddymoney.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}